#!/usr/bin/env bash
# SessionStart hook for seo-superpowers plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read seo-triage content
seo_triage_content=$(cat "${PLUGIN_ROOT}/skills/seo-triage/SKILL.md" 2>&1 || echo "Error reading seo-triage skill")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

seo_triage_escaped=$(escape_for_json "$seo_triage_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have SEO Superpowers.\n\n**Below is the full content of your 'seo-superpowers:seo-triage' skill - your SEO router. For all other skills, use the 'Skill' tool:**\n\n${seo_triage_escaped}\n\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
